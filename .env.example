# =============================================================================
# Chat Agent — environment variables
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# =============================================================================

# --- Core LLM (Google Gemini) -----------------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- E2B Sandbox (code execution) -------------------------------------------
# Get a key at https://e2b.dev/dashboard
E2B_API_KEY=your_e2b_api_key_here
# Leave blank to fall back to E2B's default `code-interpreter` template.
E2B_TEMPLATE_ID=

# --- Tavily (web search tool) -----------------------------------------------
# Get a key at https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# --- Logging -----------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Optional: alternate LLM providers --------------------------------------
# Only required if you switch LLM_PROVIDER / SEARCH_TOOL_LLM_PROVIDER away
# from `google` in config/settings.py.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=
